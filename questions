  </script>
</head>

<body>
  <header>
    <div class="brand">
      <div>
        <h1>SEITEL — Banco de ítems</h1>
        <small>Modo práctica, simulacro y PRETEST/POSTTEST (sin backend; ejecución en cliente).</small>
      </div>
    </div>
    <div class="pill" id="statusPill">Inicializando…</div>
  </header>

  <main>
    <div class="grid">
      <!-- Panel de control -->
      <section class="card">
        <h2>Configuración</h2>

        <div class="row">
          <div style="flex:1; min-width:220px;">
            <label for="mode">Modalidad</label>
            <select id="mode">
              <option value="practice10">Práctica (10 preguntas)</option>
              <option value="mock20">Simulacro (20 preguntas)</option>
              <option value="pretest">PRETEST (20 preguntas, 15 min, sin feedback)</option>
              <option value="posttest">POSTTEST (20 preguntas, 15 min, sin feedback)</option>
            </select>
          </div>
        </div>

        <div class="row" style="margin-top:10px">
          <div style="flex:1; min-width:220px;">
            <label for="source">Banco</label>
            <select id="source">
              <option value="temas">Temas</option>
              <option value="examenes">Exámenes pasadas convocatorias</option>
            </select>
          </div>
          <div style="flex:1; min-width:220px;">
            <label for="topic">Tema</label>
            <select id="topic"></select>
          </div>
        </div>

        <div class="row" style="margin-top:10px">
          <div style="flex:1; min-width:220px;">
            <label for="level">Nivel</label>
            <select id="level">
              <option value="todos">Todos</option>
              <option value="basico">Básico</option>
              <option value="avanzado">Avanzado</option>
              <option value="examen">Examen</option>
            </select>
          </div>
          <div style="flex:1; min-width:220px;">
            <label for="shuffle">Aleatorizar</label>
            <select id="shuffle">
              <option value="yes">Sí</option>
              <option value="no">No</option>
            </select>
          </div>
        </div>

        <div class="hr"></div>

        <div class="notice" id="modeNotice">
          En <b>PRETEST/POSTTEST</b>: 15 minutos, 20 ítems, <b>sin feedback</b> y <b>sin retroceso</b>.
        </div>

        <div class="footerActions" style="margin-top:12px">
          <div class="leftActions">
            <button class="btn primary" id="startBtn">Comenzar</button>
            <button class="btn danger" id="resetBtn">Reiniciar</button>
          </div>
        </div>

        <div class="meta" style="margin-top:12px">
          <div>Ítems cargados: <b id="loadedCount">—</b></div>
          <div>Selección: <b id="selectedCount">—</b></div>
        </div>

        <div class="hr"></div>

        <p style="margin:0; font-size:12px; color:var(--muted)">
          Nota técnica: El banco principal se carga desde <code>questions.json</code>. PRETEST/POSTTEST se integran en el propio HTML. :contentReference[oaicite:3]{index=3} :contentReference[oaicite:4]{index=4} :contentReference[oaicite:5]{index=5}
        </p>
      </section>

      <!-- Área de test -->
      <section class="card" id="testCard">
        <div id="preStart" class="notice">
          Configura la modalidad y pulsa <b>Comenzar</b>.
          <div style="margin-top:8px">
            Si usas esta página desde <code>index.html</code>, puedes abrirla como <code>questions.html</code> y enlazarla desde el botón de “Comenzar”.
          </div>
        </div>

        <div id="inTest" class="hidden">
          <div class="qhead">
            <div style="flex:1">
              <p class="qsub" id="qMeta">Pregunta —</p>
              <h2 class="qtitle" id="qText">—</h2>
            </div>
            <div style="min-width:240px; text-align:right">
              <div class="timer hidden" id="timerPill">15:00</div>
              <div class="progress" aria-label="Progreso del test">
                <div class="bar" id="progressBar"></div>
              </div>
              <p class="qsub" id="progressText">0 / 0</p>
            </div>
          </div>

          <div class="answers" id="answers"></div>

          <div class="feedback" id="feedback"></div>

          <div class="footerActions">
            <div class="leftActions">
              <button class="btn" id="prevBtn">Anterior</button>
              <button class="btn" id="nextBtn">Siguiente</button>
            </div>
            <div class="rightActions">
              <button class="btn primary" id="finishBtn">Finalizar</button>
            </div>
          </div>
        </div>

        <div id="result" class="hidden result">
          <h2>Resultado</h2>
          <div class="big" id="scoreBig">—</div>
          <div class="muted" id="scoreDetail">—</div>
          <div class="hr"></div>
          <div class="muted">
            Recomendación operativa: realiza una <b>captura de pantalla</b> para evidencias de investigación (si procede).
          </div>
          <div style="margin-top:12px">
            <button class="btn primary" id="againBtn">Hacer otro test</button>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    /***********************
     * 1) PRETEST / POSTTEST (20 ítems cada uno)
     *    Estructura: { pregunta, opciones[], correcta }
     ***********************/
    const PRETEST = [
      {
        pregunta: "¿Cuáles son las tres tendencias que existieron desde el principio en el campo de la Tecnología Educativa?",
        opciones: [
          "La tendencia conductista, la tendencia cognitivista y la tendencia constructivista, que representan las tres grandes corrientes psicológicas que han fundamentado el diseño instruccional a lo largo del siglo XX",
          "La tendencia presencial, la tendencia semipresencial y la tendencia en línea, que reflejan la evolución de los formatos de enseñanza mediada por tecnología desde los años 80 hasta la actualidad",
          "La tendencia preservativa o normativa, la pedagogía medial-funcional o adaptativa y la apropiación reflexiva práctica, activa y crítica de los medios como portadores de contenidos y mensajes",
          "La tendencia instrumentalista, la tendencia humanista y la tendencia crítica, que representan los tres grandes paradigmas que han orientado la investigación en tecnología educativa a lo largo del último tercio del siglo XX"
        ],
        correcta: 2
      },
      {
        pregunta: "¿Qué señala Wagner (2012) sobre la distancia entre el sistema educativo actual y las necesidades reales de la sociedad de la información?",
        opciones: [
          "Afirma que las escuelas y universidades están ofreciendo una formación excesivamente especializada en competencias digitales, descuidando los conocimientos fundamentales de las disciplinas académicas tradicionales",
          "Sostiene que los estudiantes de hoy no están preparados para afrontar los retos que la sociedad les demanda porque las escuelas y universidades están demasiado preocupadas en instruirles para unos exámenes que nada tienen que ver con dichos retos",
          "Defiende que la brecha entre la formación académica y las necesidades del mercado laboral solo puede superarse mediante la colaboración directa entre las instituciones educativas y las empresas tecnológicas privadas",
          "Concluye que la solución a esta distancia reside en la digitalización completa de los sistemas educativos, eliminando los exámenes tradicionales y sustituyéndolos por portafolios de competencias digitales"
        ],
        correcta: 1
      },
      {
        pregunta: "¿Qué informe de la «National School Board Association» evidenció en 2010 sobre el uso de Internet por parte de los estudiantes?",
        opciones: [
          "Que el 100% de los estudiantes con acceso a Internet lo utilizaba exclusivamente con fines de entretenimiento, sin que existiera evidencia de usos educativos espontáneos fuera del horario escolar",
          "Que el 96% de los estudiantes con acceso a Internet empleaba herramientas de interacción social con texto, imágenes y vídeo, y que incluso niños de Educación Primaria eran ya creadores de contenidos multimedia",
          "Que el uso de herramientas de interacción social en Internet correlacionaba negativamente con el rendimiento académico en todas las etapas educativas, siendo los estudiantes de mayor rendimiento los que menos las utilizaban",
          "Que solo el 30% de los estudiantes con acceso a Internet era capaz de crear contenidos multimedia de forma autónoma, siendo la mayoría consumidores pasivos de información sin competencias de producción digital"
        ],
        correcta: 1
      },
      {
        pregunta: "¿Qué permite la licencia Creative Commons en el contexto del uso de materiales didácticos digitales creados por docentes?",
        opciones: [
          "Permite que el docente registre sus materiales digitales como propiedad intelectual exclusiva, impidiendo que otros docentes los utilicen, modifiquen o redistribuyan sin el pago de una tasa de licencia previamente establecida",
          "Garantiza que los materiales solo puedan ser utilizados por los estudiantes del propio docente que los creó, protegiendo la autoría y evitando que los recursos digitales sean empleados fuera del contexto para el que fueron diseñados",
          "Permite que el trabajo se pueda compartir y redistribuir de forma legal, pudiendo realizar modificaciones y mejoras para su uso posterior, garantizando los derechos de la autoría y valorando el trabajo, esfuerzo y contribución del docente al desarrollo de la didáctica con base en TIC",
          "Obliga a todos los docentes que utilicen materiales con esta licencia a publicar sus propias adaptaciones en el mismo repositorio donde encontraron el recurso original, generando una red de intercambio bidireccional y obligatorio"
        ],
        correcta: 2
      },
      {
        pregunta: "Según Cope y Kalantzis (2009), el Cambio 4 «Ampliar la gama y combinación de los modos de representación» señala una brecha entre docentes y estudiantes. ¿En qué consiste exactamente esa brecha?",
        opciones: [
          "Los estudiantes prefieren contenidos escritos mientras los docentes apuestan por lo audiovisual",
          "Los docentes dominan mejor las herramientas digitales, pero no las integran curricularmente",
          "Los estudiantes carecen de alfabetización digital suficiente para aprovechar los nuevos medios",
          "Los estudiantes ya explotan las posibilidades de los nuevos medios mientras los educadores aún no han hecho un uso suficiente de ellas"
        ],
        correcta: 3
      },
      {
        pregunta: "Según la Fundación Curalia (2012), ¿qué capacidad define exclusivamente el enfoque del Nivel 3 del smartphone educativo?",
        opciones: [
          "Valorar críticamente el trabajo de compañeros durante actividades grupales dentro del aula",
          "Utilizar juegos y aplicaciones interactivas para afianzar contenidos curriculares",
          "Participar activamente en el diseño, creación y publicación de actividades y proyectos mediante las herramientas del smartphone",
          "Consumir contenidos digitales de forma autónoma en cualquier lugar y momento"
        ],
        correcta: 2
      },
      {
        pregunta: "¿Qué institución fue pionera en la creación del OpenCourseWare (OCW) y en qué año lo lanzó?",
        opciones: [
          "El Instituto Tecnológico de Massachusetts (MIT), que en el año 2001 creó el OpenCourseWare como iniciativa pionera de acceso libre y gratuito a materiales académicos",
          "La Universidad de Stanford, que en 2008 lanzó el OpenCourseWare como plataforma para ofrecer cursos de inteligencia artificial de forma gratuita",
          "La Universidad de Harvard, que en 2012 impulsó el OpenCourseWare junto al MIT como respuesta a la creciente demanda de formación en abierto",
          "La UNESCO, que en 2001 promovió el OpenCourseWare como parte del Informe Delors sobre las competencias necesarias para el siglo XXI"
        ],
        correcta: 0
      },
      {
        pregunta: "¿Qué característica diferenciadora ofrece Social Mention respecto a otros buscadores de monitorización en redes sociales?",
        opciones: [
          "Además de buscar menciones en tiempo real en medios sociales, ofrece una valoración de la marca o palabra insertada y cuenta con Social Mention Alerts para recibir avisos programados cuando la palabra clave sea mencionada",
          "Permite filtrar contenidos por idioma y período de tiempo y ofrece suscripción a un canal RSS asociado a cada búsqueda realizada en blogs y microblogs",
          "Rastrea noticias de más de 50.000 medios europeos permitiendo filtrar por región, fuentes, temáticas y período de tiempo combinándolo con Google Alerts",
          "Facilita la gestión colaborativa de proyectos permitiendo crear un timing de acciones y asignarlas a personas concretas con alertas automáticas por correo"
        ],
        correcta: 0
      },
      {
        pregunta: "¿Cuál es la función principal de la aplicación Quiver en el ámbito educativo?",
        opciones: [
          "Permitir la descarga de modelos tridimensionales anatómicos para visualizarlos directamente en el espacio del aula sin necesidad de imprimir ningún material físico",
          "Crear marcadores digitales personalizados que generan escenarios de realidad aumentada a partir de fotografías tomadas con la cámara del dispositivo móvil",
          "Colorear láminas impresas obtenidas de la web para que, mediante la cámara del dispositivo móvil, los dibujos cobren vida en escenarios de Realidad Aumentada útiles para el aprendizaje",
          "Funcionar como plataforma de videoconferencia educativa enriquecida con elementos tridimensionales para conectar aulas de distintos países en tiempo real"
        ],
        correcta: 2
      },
      {
        pregunta: "¿Qué es Blender y cuáles son sus características más relevantes para el ámbito educativo?",
        opciones: [
          "Es una aplicación móvil exclusiva para iOS que permite crear marcadores de realidad aumentada a partir de fotografías del entorno para usarlos en clases de ciencias naturales",
          "Es una plataforma web de modelado 3D diseñada específicamente para escolares de primaria, con interfaz simplificada y limitada a formas geométricas básicas de colores",
          "Es un programa multiplataforma de software libre dedicado al modelado, animación y creación de gráficos tridimensionales para representar objetos de ciencias como estructuras anatómicas, biológicas o elementos de laboratorio",
          "Es una herramienta de diseño exclusiva para dispositivos iPad que permite modelar objetos en tres dimensiones para su impresión con impresoras 3D escolares de bajo coste"
        ],
        correcta: 2
      },
      {
        pregunta: "¿Qué responsabilidad comparten Gobierno y Administraciones educativas según el art. 97 LO 3/2018?",
        opciones: [
          "Regular redes sociales",
          "Incluir competencia digital y prevención de riesgos en currículo",
          "Sustituir legislación",
          "Automatizar enseñanza"
        ],
        correcta: 1
      },
      {
        pregunta: "¿Qué establece el artículo 83.1 de la LO 3/2018 sobre educación digital?",
        opciones: [
          "Regulación exclusiva del profesorado",
          "Inserción del alumnado en sociedad digital y uso seguro",
          "Eliminación TIC",
          "Sustitución currículo"
        ],
        correcta: 1
      },
      {
        pregunta: "Si consideramos los diferentes niveles de uso educativo del smartphone, cuando este dispositivo es utilizado como apoyo para consumir materiales complementarios como podcasts, vídeos y lecturas, estaríamos ante el nivel:",
        opciones: ["4","3","2","1"],
        correcta: 3
      },
      {
        pregunta: "«Scratch» es un programa que tiene diferentes beneficios en los procesos de enseñanza-aprendizaje, pero por sus características no es recomendable su uso para:",
        opciones: [
          "Alumnado con sobredotación intelectual",
          "Alumnado con dificultades de aprendizaje",
          "Alumnado con autismo o discapacidad intelectual",
          "Ninguna de las opciones anteriores es correcta"
        ],
        correcta: 3
      },
      {
        pregunta: "Los cursos MOOC se han bifurcado en dos tendencias principales, señale qué opción es la correcta:",
        opciones: ["SOOCs y GROOCs","SPOCs y COOCs","dMOOCs y zMOOCs","cMOOCs y xMOOCs"],
        correcta: 3
      },
      {
        pregunta: "En un centro educativo, el estudiante puede otorgar su consentimiento para el tratamiento de sus datos cuando tiene:",
        opciones: ["12 años","16 años","14 años","18 años"],
        correcta: 2
      },
      {
        pregunta: "EVOKE:",
        opciones: ["Es una aplicación de realidad aumentada","Es una aplicación de realidad virtual","Es un juego experiencial","Es una red social educativa"],
        correcta: 2
      },
      {
        pregunta: "Scratch está basado en el lenguaje de programación:",
        opciones: ["HTML","COBOL","LOGO","C++"],
        correcta: 2
      },
      {
        pregunta: "El proyecto DigCompEdu, destinado a orientar la formación y promover en las aulas una integración efectiva y educativa de las competencias digitales, contempla 5 niveles concretados en áreas de competencias. Indique cuál de las siguientes forma parte de dichas áreas de competencias:",
        opciones: ["Seguridad en la red","Creación de contenidos digitales","Comunicación y colaboración on line","Todas son correctas"],
        correcta: 3
      },
      {
        pregunta: "Los derechos que la Ley de propiedad intelectual reconoce a los autores de las obras son:",
        opciones: ["Derechos morales y patrimoniales","Derechos de autoría y distribución","Derechos de marca y modificación","Derecho a la libertad de expresión y opinión"],
        correcta: 0
      }
    ];

    const POSTTEST = [
      {
