    /***********************
     * 2) Estado global
     ***********************/
    const $ = (id) => document.getElementById(id);

    const statusPill = $("statusPill");
    const modeSel = $("mode");
    const sourceSel = $("source");
    const topicSel = $("topic");
    const levelSel = $("level");
    const shuffleSel = $("shuffle");
    const startBtn = $("startBtn");
    const resetBtn = $("resetBtn");

    const loadedCount = $("loadedCount");
    const selectedCount = $("selectedCount");

    const modeNotice = $("modeNotice");

    const preStart = $("preStart");
    const inTest = $("inTest");
    const resultBox = $("result");

    const qMeta = $("qMeta");
    const qText = $("qText");
    const answersBox = $("answers");
    const feedbackBox = $("feedback");
    const progressBar = $("progressBar");
    const progressText = $("progressText");
    const prevBtn = $("prevBtn");
    const nextBtn = $("nextBtn");
    const finishBtn = $("finishBtn");
    const againBtn = $("againBtn");

    const timerPill = $("timerPill");

    let bank = null;         // questions.json completo
    let selected = [];       // ítems seleccionados para el test actual
    let current = 0;
    let answers = [];        // respuestas del usuario (índice) o null
    let locked = false;      // para bloquear (pre/post)
    let showFeedback = true; // práctica/simulacro sí; pre/post no
    let allowBack = true;    // pre/post no

    // Temporizador
    let timerSeconds = null;
    let timerHandle = null;

    /***********************
     * 3) Utilidades
     ***********************/
    function shuffleArray(arr){
      const a = arr.slice();
      for(let i=a.length-1; i>0; i--){
        const j = Math.floor(Math.random()*(i+1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function fmtTime(s){
      const mm = String(Math.floor(s/60)).padStart(2,"0");
      const ss = String(s%60).padStart(2,"0");
      return `${mm}:${ss}`;
    }

    function stopTimer(){
      if(timerHandle){ clearInterval(timerHandle); timerHandle = null; }
    }

    function startTimerIfNeeded(){
      stopTimer();
      if(timerSeconds === null) return;

      timerPill.classList.remove("hidden");
      timerPill.textContent = fmtTime(timerSeconds);

      timerHandle = setInterval(() => {
        timerSeconds--;
        timerPill.textContent = fmtTime(Math.max(0,timerSeconds));
        if(timerSeconds <= 0){
          stopTimer();
          finishTest(true);
        }
      }, 1000);
    }

    /***********************
     * 4) Carga del banco principal (questions.json)
     ***********************/
    async function loadBank(){
      statusPill.textContent = "Cargando questions.json…";
      try{
        const res = await fetch("./questions.json", { cache: "no-store" });
        if(!res.ok) throw new Error("No se pudo cargar questions.json");
        bank = await res.json();
        statusPill.textContent = "Banco cargado";
        initSelectors();
      }catch(e){
        statusPill.textContent = "Error: questions.json";
        console.error(e);
        // Aun así permitimos PRE/POST sin questions.json
        bank = { temas:{}, examenes:{} };
        initSelectors();
      }
    }

    function initSelectors(){
      // Rellenar temas inicialmente
      refreshTopics();
      refreshCounts();

      modeSel.addEventListener("change", () => {
        const isPrePost = (modeSel.value === "pretest" || modeSel.value === "posttest");
        // En PRE/POST: no depende del banco externo; desactivamos selectores de temas
        sourceSel.disabled = isPrePost;
        topicSel.disabled = isPrePost;
        levelSel.disabled = isPrePost;
        shuffleSel.disabled = false; // sí podemos aleatorizar dentro del pre/post

        modeNotice.style.display = isPrePost ? "block" : "none";
        refreshCounts();
      });

      sourceSel.addEventListener("change", () => {
        refreshTopics();
        refreshCounts();
      });
      topicSel.addEventListener("change", refreshCounts);
      levelSel.addEventListener("change", refreshCounts);
      shuffleSel.addEventListener("change", refreshCounts);

      startBtn.addEventListener("click", startTest);
      resetBtn.addEventListener("click", hardReset);
      prevBtn.addEventListener("click", () => goto(current - 1));
      nextBtn.addEventListener("click", () => goto(current + 1));
      finishBtn.addEventListener("click", () => finishTest(false));
      againBtn.addEventListener("click", hardReset);

      // Estado inicial
      modeSel.dispatchEvent(new Event("change"));
    }

    function refreshTopics(){
      const src = sourceSel.value; // temas | examenes
      const obj = (bank && bank[src]) ? bank[src] : {};
      const keys = Object.keys(obj);

      topicSel.innerHTML = "";
      if(keys.length === 0){
        const opt = document.createElement("option");
        opt.value = "";
        opt.textContent = "— (no disponible)";
        topicSel.appendChild(opt);
        return;
      }

      for(const k of keys){
        const opt = document.createElement("option");
        opt.value = k;
        opt.textContent = k;
        topicSel.appendChild(opt);
      }
    }

    function getPoolFromBank(){
      const src = sourceSel.value;
      const topic = topicSel.value;
      const level = levelSel.value;

      const obj = (bank && bank[src] && bank[src][topic]) ? bank[src][topic] : [];
      const pool = obj.filter(q => {
        if(level === "todos") return true;
        return (q.nivel || "").toLowerCase() === level.toLowerCase();
      });

      return pool;
    }

    function refreshCounts(){
      const m = modeSel.value;
      if(m === "pretest"){
        loadedCount.textContent = PRETEST.length;
        selectedCount.textContent = "20";
        return;
      }
      if(m === "posttest"){
        loadedCount.textContent = POSTTEST.length;
        selectedCount.textContent = "20";
        return;
      }

      const pool = getPoolFromBank();
      loadedCount.textContent = pool.length;

      const need = (m === "practice10") ? 10 : 20;
      selectedCount.textContent = Math.min(need, pool.length);
    }

    /***********************
     * 5) Construcción del test
     ***********************/
    function buildSelection(){
      const m = modeSel.value;
      const doShuffle = (shuffleSel.value === "yes");

      locked = false;
      showFeedback = true;
      allowBack = true;
      timerSeconds = null;

      if(m === "pretest"){
        selected = doShuffle ? shuffleArray(PRETEST) : PRETEST.slice();
        selected = selected.slice(0, 20);
        locked = true;
        showFeedback = false;
        allowBack = false;
        timerSeconds = 15 * 60;
        return;
      }

      if(m === "posttest"){
        selected = doShuffle ? shuffleArray(POSTTEST) : POSTTEST.slice();
        selected = selected.slice(0, 20);
        locked = true;
        showFeedback = false;
        allowBack = false;
        timerSeconds = 15 * 60;
        return;
      }

      // práctica / simulacro desde banco externo
      const pool = getPoolFromBank();
      const need = (m === "practice10") ? 10 : 20;

      let base = doShuffle ? shuffleArray(pool) : pool.slice();
      selected = base.slice(0, Math.min(need, base.length));

      locked = false;
      showFeedback = true;
      allowBack = true;
      timerSeconds = null; // sin temporizador por defecto
    }

    function startTest(){
      buildSelection();
      if(selected.length === 0){
        alert("No hay ítems disponibles para la selección actual.");
        return;
      }

      answers = new Array(selected.length).fill(null);
      current = 0;

      preStart.classList.add("hidden");
      resultBox.classList.add("hidden");
      inTest.classList.remove("hidden");

      feedbackBox.style.display = "none";
      render();

      prevBtn.disabled = true;
      nextBtn.disabled = (selected.length <= 1);
      finishBtn.disabled = false;

      // Reglas pre/post
      if(!allowBack){
        prevBtn.classList.add("hidden");
      }else{
        prevBtn.classList.remove("hidden");
      }

      startTimerIfNeeded();
    }

    function render(){
      const q = selected[current];
      const idx = current + 1;

      const srcLabel = (modeSel.value === "pretest") ? "PRETEST"
                     : (modeSel.value === "posttest") ? "POSTTEST"
                     : `${sourceSel.value.toUpperCase()} · ${topicSel.value || "—"} · ${levelSel.value.toUpperCase()}`;

      qMeta.textContent = `${srcLabel} — Pregunta ${idx} de ${selected.length}`;
      qText.textContent = q.pregunta;

      // Progreso
      const pct = ((idx-1) / (selected.length-1 || 1)) * 100;
      progressBar.style.width = `${Math.max(0, Math.min(100, pct))}%`;
      progressText.textContent = `${idx} / ${selected.length}`;

      // Botones nav
      prevBtn.disabled = (current === 0);
      nextBtn.disabled = (current >= selected.length - 1);

      // En pre/post: “Siguiente” si no respondido aún se mantiene activo,
      // pero no permitimos volver: allowBack=false ya lo controla.
      // Render opciones
      answersBox.innerHTML = "";
      const chosen = answers[current];

      q.opciones.forEach((optTxt, optIdx) => {
        const b = document.createElement("button");
        b.className = "opt";
        b.type = "button";
        b.textContent = optTxt;

        // Estados de corrección solo si hay feedback
        if(showFeedback && chosen !== null){
          if(optIdx === q.correcta) b.classList.add("correct");
          if(optIdx === chosen && chosen !== q.correcta) b.classList.add("wrong");
          b.disabled = true;
        }

        // En pre/post: al responder bloqueamos esa pregunta y avanzamos automáticamente
        if(!showFeedback && chosen !== null){
          b.disabled = true;
        }

        b.addEventListener("click", () => choose(optIdx));
        answersBox.appendChild(b);
      });

      // Feedback (solo práctica/simulacro)
      if(showFeedback && chosen !== null){
        const ok = (chosen === q.correcta);
        feedbackBox.style.display = "block";
        const expl = (q.explicacion) ? ` ${q.explicacion}` : "";
        feedbackBox.innerHTML = ok
          ? `<strong>Correcta.</strong>${expl ? "<br/>" + expl : ""}`
          : `<strong>Incorrecta.</strong> La opción correcta es: <strong>${q.opciones[q.correcta]}</strong>${expl ? "<br/>" + expl : ""}`;
      }else{
        feedbackBox.style.display = "none";
      }
    }

    function choose(optIdx){
      // Si ya contestó, no permitir cambios (especialmente en pre/post)
      if(answers[current] !== null) return;

      answers[current] = optIdx;

      if(showFeedback){
        render(); // muestra feedback y bloquea
        return;
      }

      // PRE/POST: sin feedback; autoadvance si no es última
      render();
      if(current < selected.length - 1){
        goto(current + 1);
      }else{
        finishTest(false);
      }
    }

    function goto(i){
      if(i < 0 || i >= selected.length) return;

      // No permitir retroceso en pre/post
      if(!allowBack && i < current) return;

      current = i;
      render();
    }

    function finishTest(autoByTimeout){
      stopTimer();

      // Puntuación
      let correct = 0;
      for(let i=0;i<selected.length;i++){
        if(answers[i] === selected[i].correcta) correct++;
      }
      const total = selected.length;

      inTest.classList.add("hidden");
      resultBox.classList.remove("hidden");

      const pct = Math.round((correct/total)*100);
      $("scoreBig").textContent = `${correct} / ${total}`;
      $("scoreDetail").textContent = autoByTimeout
        ? `Tiempo agotado. Rendimiento: ${pct}%.`
        : `Rendimiento: ${pct}%.`;

      // Reset UI nav
      timerPill.classList.add("hidden");
    }

    function hardReset(){
      stopTimer();
      selected = [];
      answers = [];
      current = 0;
      locked = false;
      timerSeconds = null;

      inTest.classList.add("hidden");
      resultBox.classList.add("hidden");
      preStart.classList.remove("hidden");

      prevBtn.classList.remove("hidden");
      timerPill.classList.add("hidden");

      refreshCounts();
    }

    // Init
    loadBank();
  </script>
